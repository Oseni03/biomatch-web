generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  donor
  hospital
  admin
}

enum IncentiveType {
  hmo_voucher
  gym_discount
}

enum ClaimStatus {
  pending
  approved
  redeemed
}

enum BloodGroup {
  A_PLUS
  A_MINUS
  B_PLUS
  B_MINUS
  AB_PLUS
  AB_MINUS
  O_PLUS
  O_MINUS
}

model HospitalBank {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospitalName String
  location     String
  inventory    Json     @default("{\"A+\": 0, \"A-\": 0, \"B+\": 0, \"B-\": 0, \"AB+\": 0, \"AB-\": 0, \"O+\": 0, \"O-\": 0}")
  managedById  String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  managedBy User? @relation(fields: [managedById], references: [id], onDelete: SetNull)

  @@map("hospital_banks")
}

model Wallet {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @db.Uuid
  points            Int      @default(0)
  lifetimeDonations Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model IncentiveClaim {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String        @db.Uuid
  type      IncentiveType
  status    ClaimStatus   @default(pending)
  metadata  Json          @default("{}")
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("incentives_claims")
}

model User {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  email             String
  emailVerified     Boolean     @default(false)
  image             String?
  bloodGroup        BloodGroup?
  genotype          String?
  role              Role        @default(donor)
  updatedHealthInfo Json        @default("{}")
  lastDonationDate  DateTime?   @db.Timestamptz(6)
  createdAt         DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @db.Timestamptz(6)

  sessions     Session[]
  accounts     Account[]
  wallet       Wallet?
  managedBanks HospitalBank[]
  claims       IncentiveClaim[]

  @@unique([email])
  @@index([role])
  @@index([bloodGroup])
  @@index([lastDonationDate])
  @@map("user")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  @@index([identifier])
  @@map("verification")
}
